{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist-tsc/node",
    "rootDir": "."
  },
  "include": ["vite.config.ts"]
}
