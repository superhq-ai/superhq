---
// Raised card wrapper. Used across Features, Agents, Shortcuts, etc.
// Deliberately minimal — just a rounded rect with thin chrome border.
interface Props {
  class?: string;
  as?: string;
}

const { class: className = "", as: Tag = "div" } = Astro.props;
const classes = ["card", className].filter(Boolean).join(" ");
---

<Tag class={classes}>
  <slot />
</Tag>
