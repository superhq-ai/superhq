---
import claudeRaw from "../assets/claude.svg?raw";
import codexRaw from "../assets/codex.svg?raw";
import piRaw from "../assets/pi.svg?raw";

// Force explicit dimensions and currentColor inheritance on the svg
// root so the icons render at 26px and pick up the tile's color.
function prep(raw: string, size = 26): string {
  return raw.replace(
    /<svg\b([^>]*)>/,
    (_m, attrs) =>
      `<svg${attrs.replace(/\swidth="[^"]*"/g, "").replace(/\sheight="[^"]*"/g, "")} width="${size}" height="${size}" fill="currentColor">`,
  );
}

const agents = [
  { name: "Claude Code", svg: prep(claudeRaw) },
  { name: "OpenAI Codex", svg: prep(codexRaw) },
  { name: "Pi",           svg: prep(piRaw) },
];
---

<section class="agents">
  <div class="agents-inner">
    <span class="agents-label">Runs out of the box</span>
    <ul class="agents-list">
      {agents.map((a) => (
        <li class="agent-tile">
          <span class="agent-icon" set:html={a.svg} />
          <span>{a.name}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .agents {
    padding-block: 28px 20px;
    padding-inline: 24px;
  }

  /* width matches the screenshot's shot-wrap so the label's "R"
     aligns with the bg image's left edge */
  .agents-inner {
    max-width: 1100px;
    margin-inline: auto;
    display: flex;
    align-items: center;
    gap: 28px;
    flex-wrap: wrap;
  }

  .agents-label {
    font-family: var(--mono);
    font-size: 0.74rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-dim);
    flex-shrink: 0;
  }

  .agents-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
  }

  .agent-tile {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--fg);
    font-family: var(--mono);
    font-size: 0.9rem;
    letter-spacing: 0.005em;
  }

  .agent-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--fg);
    line-height: 0;
  }

  @media (max-width: 640px) {
    .agents { padding-block: 20px 16px; padding-inline: 16px; }
    .agents-inner { gap: 16px; }
    .agents-list { gap: 20px; }
    .agent-tile { font-size: 0.82rem; gap: 8px; }
  }
</style>
