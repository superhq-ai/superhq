---
import screenshot from "../assets/screenshot.png";
---

<section class="shot-section">
  <div class="shot-wrap">
    <img
      src={screenshot.src}
      width={screenshot.width}
      height={screenshot.height}
      alt="SuperHQ desktop app showing sandboxed agents, terminal, and review panel"
      loading="eager"
      decoding="async"
    />
  </div>
</section>

<style>
  .shot-section {
    margin-top: 60px;
    padding-inline: 24px;
  }

  .shot-wrap {
    width: 100%;
    max-width: 1100px;
    margin-inline: auto;
  }

  .shot-wrap img {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
  }

  @media (max-width: 720px) {
    .shot-section {
      margin-top: 40px;
      padding-inline: 16px;
    }
  }
</style>
