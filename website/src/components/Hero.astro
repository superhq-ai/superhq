---
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-left">
      <a
        class="announce"
        href="https://remote.superhq.ai"
        target="_blank"
        rel="noreferrer"
        data-umami-event="hero-remote-click"
      >
        <span class="announce-label">New</span>
        <span class="announce-text">Control your agents from your phone</span>
        <span class="announce-arrow" aria-hidden="true">→</span>
      </a>

      <h1 class="headline">
        Run AI coding agents<br />
        in real sandboxes.
      </h1>
    </div>

    <div class="hero-right">
      <p class="lede">
        Claude Code, OpenAI Codex, and Pi. Each in its own microVM.
        See what they're working on at a glance, then review and merge
        their changes.
      </p>

      <p class="eyebrow-reqs">Requires macOS 14+ · Apple Silicon</p>

      <div class="cta-row">
        <a
          href="https://github.com/superhq-ai/superhq/releases"
          class="pill-btn primary"
          data-umami-event="download-click"
        >
          <svg class="apple" viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true">
            <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
          </svg>
          Download for Mac
        </a>
        <a
          href="https://github.com/superhq-ai/superhq#readme"
          class="pill-btn"
          data-umami-event="learn-more-click"
        >
          Learn more <span class="arrow">→</span>
        </a>
      </div>

      <button
        type="button"
        class="brew-line"
        data-copy="brew install --cask superhq-ai/tap/superhq"
        data-umami-event="copy-install-command"
        aria-label="Copy Homebrew install command"
      >
        <span class="prompt">$</span><span class="cmd">brew install --cask superhq-ai/tap/superhq</span>
        <span class="copy-icon" aria-hidden="true">
          <svg class="icon-copy" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="5" y="5" width="8" height="8" rx="1.5"/>
            <path d="M3 11V4a1 1 0 0 1 1-1h7"/>
          </svg>
          <svg class="icon-check" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 8.5l3.2 3.2L13 4.8"/>
          </svg>
        </span>
      </button>

      <p class="install-note">
        Note: the app is not yet notarized, so macOS Gatekeeper will block
        it on first launch.{" "}
        <a
          href="https://github.com/superhq-ai/superhq#install"
          target="_blank"
          rel="noreferrer"
          data-umami-event="install-note-readme-click"
        >See the README</a> for the one-time unblock step.
      </p>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: 88px;
    padding-bottom: 48px;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(0, 1fr);
    gap: 48px;
    align-items: start;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 18px;
    min-width: 0;
  }

  .announce {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 6px 12px 6px 6px;
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    background: var(--ink-1);
    color: var(--fg-dim);
    font-family: var(--mono);
    font-size: 0.78rem;
    transition: border-color 140ms ease, background 140ms ease, color 140ms ease;
  }
  .announce:hover {
    border-color: var(--line-hover);
    background: var(--ink-2);
    color: var(--fg);
    opacity: 1;
  }
  .announce-label {
    padding: 2px 9px;
    border-radius: 999px;
    background: var(--fg);
    color: var(--ink-0);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .announce-arrow {
    transition: transform 160ms ease;
    color: var(--fg-dimmer);
  }
  .announce:hover .announce-arrow {
    transform: translateX(3px);
    color: var(--fg);
  }

  .eyebrow-reqs {
    font-family: var(--mono);
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-dimmer);
    margin: -4px 0 0;
  }

  .headline {
    max-width: none;
    margin: 0;
    font-size: clamp(1.8rem, 4vw, 3rem);
    line-height: 1.08;
    letter-spacing: -0.04em;
  }

  .hero-right {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 18px;
    min-width: 0;
  }

  .lede {
    font-family: var(--sans);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--fg-dim);
    max-width: 44ch;
    margin: 0 0 4px;
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .brew-line {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0;
    background: transparent;
    border: 0;
    color: var(--fg-dimmer);
    font-family: var(--mono);
    font-size: 0.78rem;
    cursor: pointer;
    max-width: 100%;
    transition: color 140ms ease;
  }
  .brew-line:hover { color: var(--fg); }
  .brew-line .prompt { color: var(--fg-mute); }
  .brew-line .cmd {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }
  .brew-line .copy-icon {
    position: relative;
    width: 13px;
    height: 13px;
    flex-shrink: 0;
    color: inherit;
    opacity: 0.7;
  }
  .brew-line .copy-icon svg {
    position: absolute;
    inset: 0;
    width: 13px;
    height: 13px;
    transition: opacity 180ms ease, transform 180ms ease;
  }
  .brew-line .icon-check {
    opacity: 0;
    transform: scale(0.6);
    color: var(--fg);
  }
  .brew-line.copied .icon-copy {
    opacity: 0;
    transform: scale(0.6);
  }
  .brew-line.copied .icon-check {
    opacity: 1;
    transform: scale(1);
  }
  .brew-line:hover .copy-icon { opacity: 1; }

  .install-note {
    font-family: var(--mono);
    font-size: 0.74rem;
    line-height: 1.5;
    color: var(--fg-dimmer);
    max-width: 46ch;
    margin: -6px 0 0;
  }
  .install-note a {
    color: var(--fg-dim);
    text-decoration: underline;
    text-decoration-color: var(--line-strong);
    text-underline-offset: 2px;
    transition: color 140ms ease, text-decoration-color 140ms ease;
  }
  .install-note a:hover {
    color: var(--fg);
    text-decoration-color: var(--fg);
  }

  @media (max-width: 960px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 32px;
      align-items: start;
    }
    .headline { max-width: 22ch; }
  }
  @media (max-width: 720px) {
    .hero { padding-top: 64px; }
  }
  @media (max-width: 640px) {
    .brew-line { max-width: 92vw; }
    .brew-line .cmd { max-width: 70vw; }
  }
</style>

<script>
  const btn = document.querySelector<HTMLButtonElement>(".brew-line");
  let resetTimer: ReturnType<typeof setTimeout> | undefined;

  btn?.addEventListener("click", async () => {
    const text = btn.dataset.copy ?? "";
    try {
      await navigator.clipboard.writeText(text);
      btn.classList.add("copied");
      if (resetTimer) clearTimeout(resetTimer);
      resetTimer = setTimeout(() => btn.classList.remove("copied"), 1600);
    } catch {}
  });
</script>
