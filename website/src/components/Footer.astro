---
import icon from "../assets/icon.svg";
const year = new Date().getFullYear();

const groups = [
  {
    label: "Product",
    links: [
      { label: "Download",  href: "https://github.com/superhq-ai/superhq/releases", ev: "footer-releases-click" },
      { label: "Remote",    href: "https://remote.superhq.ai",                        ev: "footer-remote-click" },
      { label: "Changelog", href: "https://github.com/superhq-ai/superhq/blob/main/CHANGELOG.md", ev: "footer-changelog-click" },
    ],
  },
  {
    label: "Source",
    links: [
      { label: "GitHub", href: "https://github.com/superhq-ai/superhq",         ev: "footer-github-click" },
      { label: "README", href: "https://github.com/superhq-ai/superhq#readme",  ev: "footer-readme-click" },
    ],
  },
  {
    label: "Built with",
    links: [
      { label: "Shuru sandbox", href: "https://github.com/superhq-ai/shuru", ev: "footer-shuru-click" },
      { label: "GPUI",          href: "https://gpui.rs",                      ev: "footer-gpui-click" },
    ],
  },
];
---

<footer class="footer">
  <div class="container foot-inner">
    <div class="foot-brand">
      <img src={icon.src} alt="" width="28" height="28" />
      <span>SUPERHQ</span>
    </div>

    <nav class="foot-groups" aria-label="Footer">
      {groups.map((g) => (
        <div class="foot-group">
          <div class="foot-group-label">{g.label}</div>
          <ul class="foot-group-list">
            {g.links.map((l) => (
              <li>
                <a class="foot-group-link" href={l.href} data-umami-event={l.ev}>{l.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </nav>

    <div class="foot-copy">
      <span>AGPL-3.0</span>
      <span class="sep">·</span>
      <span>© {year}</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: 120px;
    padding-block: 56px 48px;
    border-top: 1px solid var(--line-strong);
  }

  .foot-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    column-gap: 56px;
    row-gap: 40px;
    align-items: start;
  }

  .foot-brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: var(--fg);
    font-family: var(--mono);
    letter-spacing: 0.08em;
    font-size: 0.86rem;
  }
  .foot-brand img {
    border-radius: 6px;
    display: block;
  }

  .foot-groups {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 32px;
    justify-self: end;
    min-width: 0;
  }

  .foot-group-label {
    margin: 0 0 14px;
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-dimmer);
    font-weight: 500;
  }

  .foot-group-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .foot-group-list li { list-style: none; }

  .foot-group-link {
    color: var(--fg-dim);
    font-family: var(--mono);
    font-size: 0.82rem;
    letter-spacing: 0.01em;
  }
  .foot-group-link:hover { color: var(--fg); opacity: 1; }

  .foot-copy {
    grid-column: 1 / -1;
    padding-top: 24px;
    border-top: 1px solid var(--line);
    display: flex;
    gap: 8px;
    font-size: 0.7rem;
    color: var(--fg-dimmer);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .foot-copy .sep { color: var(--fg-mute); }

  @media (max-width: 720px) {
    .foot-inner {
      grid-template-columns: 1fr;
      row-gap: 28px;
    }
    .foot-groups {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 24px;
      justify-self: start;
    }
  }
  @media (max-width: 420px) {
    .foot-groups { grid-template-columns: 1fr; gap: 20px; }
  }
</style>
